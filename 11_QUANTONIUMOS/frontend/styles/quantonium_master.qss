/* ==========================================
   QUANTONIUM OS - 2025 MINIMALIST DESIGN
   Modern, Clean, Production-Grade Aesthetic
   Version: 3.0 - Zero Errors, Full Qt Support
========================================== */

/* 2025 MODERN BASE */
QWidget {
    background-color: #0f0f0f;
    color: #e8e8e8;
    font-family: "Segoe UI", "SF Pro Display", "Helvetica Neue", sans-serif;
    font-size: 14px;
    font-weight: 400;
    selection-background-color: #2563eb;
    selection-color: #ffffff;
}

/* MAIN WINDOW - FULLSCREEN MODERN */
QMainWindow {
    background: qlineargradient(x1:0, y1:0, x2:1, y2:1,
        stop:0 #0f0f0f, stop:0.3 #1a1a1a, stop:0.7 #161616, stop:1 #0f0f0f);
    border: none;
}

/* MINIMALIST PANELS */
QFrame {
    background: rgba(26, 26, 26, 240);
    border: 1px solid rgba(255, 255, 255, 26);
    border-radius: 16px;
    padding: 12px;
}

/* 2025 MODERN BUTTONS */
QPushButton {
    background: qlineargradient(x1:0, y1:0, x2:0, y2:1,
        stop:0 #2563eb, stop:1 #1d4ed8);
    border: none;
    border-radius: 12px;
    padding: 14px 24px;
    color: #ffffff;
    font-weight: 600;
    font-size: 15px;
    min-height: 32px;
}

QPushButton:hover {
    background: qlineargradient(x1:0, y1:0, x2:0, y2:1,
        stop:0 #3b82f6, stop:1 #2563eb);
}

QPushButton:pressed {
    background: qlineargradient(x1:0, y1:0, x2:0, y2:1,
        stop:0 #1d4ed8, stop:1 #1e40af);
}

/* MODERN LABELS */
QLabel {
    background: transparent;
    color: #e8e8e8;
    border: none;
    font-weight: 500;
}

/* SLEEK TAB SYSTEM */
QTabWidget::pane {
    border: 1px solid rgba(255, 255, 255, 26);
    background: #1a1a1a;
    border-radius: 12px;
    margin-top: 8px;
}

QTabBar::tab {
    background: transparent;
    color: #9ca3af;
    padding: 12px 20px;
    margin-right: 4px;
    border: none;
    border-radius: 8px 8px 0px 0px;
    font-weight: 500;
}

QTabBar::tab:selected {
    background: #2563eb;
    color: #ffffff;
    font-weight: 600;
}

QTabBar::tab:hover {
    background: rgba(37, 99, 235, 76);
    color: #ffffff;
}

/* MODERN MENU BAR */
QMenuBar {
    background: rgba(15, 15, 15, 240);
    color: #e8e8e8;
    border: none;
    padding: 8px;
    font-weight: 500;
}

QMenuBar::item {
    background: transparent;
    padding: 8px 16px;
    border-radius: 8px;
    font-weight: 500;
}

QMenuBar::item:selected {
    background: rgba(37, 99, 235, 51);
    color: #ffffff;
}

/* MODERN DROPDOWN MENUS */
QMenu {
    background: #1a1a1a;
    color: #e8e8e8;
    border: 1px solid rgba(255, 255, 255, 26);
    border-radius: 12px;
    padding: 8px;
}

QMenu::item {
    background: transparent;
    padding: 10px 16px;
    border-radius: 8px;
}

QMenu::item:selected {
    background: #2563eb;
    color: #ffffff;
}

QMenu::separator {
    height: 1px;
    background: rgba(255, 255, 255, 26);
    margin: 8px 16px;
}

/* MODERN STATUS BAR */
QStatusBar {
    background: rgba(15, 15, 15, 240);
    color: #9ca3af;
    border: none;
    padding: 8px;
    font-size: 13px;
}

QStatusBar::item {
    border: none;
}

/* MODERN TOOLBAR */
QToolBar {
    background: rgba(26, 26, 26, 240);
    border: none;
    spacing: 8px;
    padding: 12px;
    border-radius: 12px;
}

QToolBar::handle {
    background: rgba(255, 255, 255, 26);
    width: 3px;
    border-radius: 2px;
    margin: 4px;
}

QToolBar QToolButton {
    background: transparent;
    border: none;
    border-radius: 8px;
    padding: 10px;
    color: #9ca3af;
    font-weight: 500;
}

QToolBar QToolButton:hover {
    background: rgba(37, 99, 235, 51);
    color: #ffffff;
}

QToolBar QToolButton:pressed {
    background: #2563eb;
    color: #ffffff;
}

/* MODERN SPLITTER */
QSplitter::handle {
    background: rgba(255, 255, 255, 26);
    width: 2px;
    height: 2px;
    border-radius: 1px;
}

QSplitter::handle:hover {
    background: #2563eb;
}

/* MODERN TEXT INPUTS */
QLineEdit {
    background: #1a1a1a;
    border: 1px solid rgba(255, 255, 255, 26);
    border-radius: 8px;
    padding: 12px 16px;
    color: #e8e8e8;
    font-size: 14px;
}

QLineEdit:focus {
    border: 2px solid #2563eb;
    background: #1f1f1f;
}

QTextEdit {
    background: #1a1a1a;
    border: 1px solid rgba(255, 255, 255, 26);
    border-radius: 12px;
    padding: 16px;
    color: #e8e8e8;
    font-size: 14px;
    line-height: 1.5;
}

QTextEdit:focus {
    border: 2px solid #2563eb;
    background: #1f1f1f;
}

/* MODERN PROGRESS BAR */
QProgressBar {
    background: #1a1a1a;
    border: 1px solid rgba(255, 255, 255, 26);
    border-radius: 8px;
    text-align: center;
    color: #e8e8e8;
    font-weight: 600;
    height: 24px;
}

QProgressBar::chunk {
    background: qlineargradient(x1:0, y1:0, x2:1, y2:0,
        stop:0 #2563eb, stop:1 #3b82f6);
    border-radius: 6px;
}

/* MODERN SCROLLBARS */
QScrollBar:vertical {
    background: rgba(26, 26, 26, 100);
    width: 12px;
    border-radius: 6px;
    border: none;
}

QScrollBar::handle:vertical {
    background: rgba(156, 163, 175, 128);
    border-radius: 6px;
    min-height: 40px;
}

QScrollBar::handle:vertical:hover {
    background: rgba(156, 163, 175, 204);
}

QScrollBar:horizontal {
    background: rgba(26, 26, 26, 100);
    height: 12px;
    border-radius: 6px;
    border: none;
}

QScrollBar::handle:horizontal {
    background: rgba(156, 163, 175, 128);
    border-radius: 6px;
    min-width: 40px;
}

QScrollBar::handle:horizontal:hover {
    background: rgba(156, 163, 175, 204);
}

QScrollBar::add-line, QScrollBar::sub-line {
    border: none;
    background: none;
}

/* MODERN LIST WIDGETS */
QListWidget {
    background: #1a1a1a;
    border: 1px solid rgba(255, 255, 255, 26);
    border-radius: 12px;
    padding: 8px;
    outline: none;
}

QListWidget::item {
    background: transparent;
    padding: 12px 16px;
    margin: 2px 0;
    border-radius: 8px;
    color: #e8e8e8;
}

QListWidget::item:selected {
    background: #2563eb;
    color: #ffffff;
}

QListWidget::item:hover {
    background: rgba(37, 99, 235, 51);
}

/* MODERN CHECKBOXES */
QCheckBox {
    color: #e8e8e8;
    spacing: 12px;
    font-weight: 500;
}

QCheckBox::indicator {
    width: 20px;
    height: 20px;
    border: 2px solid rgba(255, 255, 255, 0.3);
    border-radius: 4px;
    background: #1a1a1a;
}

QCheckBox::indicator:checked {
    background: #2563eb;
    border-color: #2563eb;
}

QCheckBox::indicator:hover {
    border-color: #2563eb;
}

/* MODERN RADIO BUTTONS */
QRadioButton {
    color: #e8e8e8;
    spacing: 12px;
    font-weight: 500;
}

QRadioButton::indicator {
    width: 20px;
    height: 20px;
    border: 2px solid rgba(255, 255, 255, 0.3);
    border-radius: 10px;
    background: #1a1a1a;
}

QRadioButton::indicator:checked {
    background: radial-gradient(circle, #2563eb 30%, #1a1a1a 30%);
    border-color: #2563eb;
}

QRadioButton::indicator:hover {
    border-color: #2563eb;
}

/* MODERN SLIDERS */
QSlider::groove:horizontal {
    border: none;
    height: 6px;
    background: #1a1a1a;
    border-radius: 3px;
}

QSlider::handle:horizontal {
    background: #2563eb;
    border: none;
    width: 20px;
    height: 20px;
    border-radius: 10px;
    margin: -7px 0;
}

QSlider::handle:horizontal:hover {
    background: #3b82f6;
}

/* DOCK WIDGETS */
QDockWidget {
    color: #e8e8e8;
    border: 1px solid rgba(255, 255, 255, 26);
    border-radius: 12px;
}

QDockWidget::title {
    background: #1a1a1a;
    padding: 16px;
    border-top-left-radius: 12px;
    border-top-right-radius: 12px;
    font-weight: 600;
    font-size: 15px;
}

/* SPECIAL QUANTUM EFFECTS - Modern Minimal */
.quantum-glow {
    color: #60a5fa;
    font-weight: 600;
}

.quantum-pulse {
    background: rgba(37, 99, 235, 0.1);
    border: 1px solid rgba(37, 99, 235, 0.3);
}

/* APP-SPECIFIC STYLES */
.rft-visualizer {
    background: rgba(37, 99, 235, 0.05);
    border-radius: 12px;
}

.crypto-container {
    background: rgba(16, 185, 129, 0.05);
    border: 1px solid rgba(16, 185, 129, 0.2);
    border-radius: 12px;
}

.system-monitor-graph {
    background: #1a1a1a;
    border: 1px solid rgba(255, 255, 255, 26);
    border-radius: 12px;
}

QMenuBar::item {
    background: transparent;
    padding: 4px 8px;
    border-radius: 3px;
}

QMenuBar::item:selected {
    background: #1a2332;
    color: #00ff88;
}

QMenu {
    background: #1a2332;
    color: #00ffcc;
    border: 1px solid #00ffcc;
    border-radius: 5px;
    padding: 2px;
}

QMenu::item {
    background: transparent;
    padding: 5px 20px;
    border-radius: 3px;
}

QMenu::item:selected {
    background: #2a3342;
    color: #00ff88;
}

QMenu::separator {
    height: 1px;
    background: #00ffcc;
    margin: 5px 10px;
}

/* Status Bar */
QStatusBar {
    background: #0f1621;
    color: #00ffcc;
    border-top: 1px solid #00ffcc;
    padding: 3px;
}

QStatusBar::item {
    border: none;
}

/* Toolbar */
QToolBar {
    background: #1a2332;
    border: 1px solid #00ffcc;
    spacing: 2px;
    padding: 3px;
}

QToolBar::handle {
    background: #00ffcc;
