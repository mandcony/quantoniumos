}

QPushButton:hover {
    background: qlineargradient(x1:0, y1:0, x2:0, y2:1,
        stop:0 #2a3342, stop:1 #1f2631);
    border-color: #00ff88;
    color: #00ff88;
}

QPushButton:pressed {
    background: qlineargradient(x1:0, y1:0, x2:0, y2:1,
        stop:0 #0f1621, stop:1 #1a2332);
    border-color: #00ccff;
    padding: 11px 19px 9px 21px;
}

/* Quantum Tab Widget */
QTabWidget::pane {
    background: rgba(10, 14, 26, 0.95);
    border: 2px solid #00ffcc;
    border-radius: 12px;
    margin-top: -2px;
}

QTabBar::tab {
    background: qlineargradient(x1:0, y1:0, x2:0, y2:1,
        stop:0 #1a2332, stop:1 #0f1621);
    color: #00ffcc;
    padding: 12px 24px;
    margin-right: 4px;
    border-top-left-radius: 8px;
    border-top-right-radius: 8px;
    border: 2px solid transparent;
}

QTabBar::tab:selected {
    background: qlineargradient(x1:0, y1:0, x2:0, y2:1,
        stop:0 #2a3342, stop:1 #1f2631);
    border-color: #00ffcc;
    border-bottom: none;
}

QTabBar::tab:hover:!selected {
    background: qlineargradient(x1:0, y1:0, x2:0, y2:1,
        stop:0 #1f2631, stop:1 #141925);
    border-color: rgba(0, 255, 204, 0.5);
}

/* Quantum Scroll Bars */
QScrollBar:vertical {
    background: #0a0e1a;
    width: 14px;
    border-radius: 7px;
    border: 1px solid rgba(0, 255, 204, 0.2);
}

QScrollBar::handle:vertical {
    background: qlineargradient(x1:0, y1:0, x2:1, y2:0,
        stop:0 #00ffcc, stop:1 #00ff88);
    border-radius: 6px;
    min-height: 30px;
}

QScrollBar::handle:vertical:hover {
    background: qlineargradient(x1:0, y1:0, x2:1, y2:0,
        stop:0 #00ff88, stop:1 #00ccff);
}

QScrollBar:horizontal {
    background: #0a0e1a;
    height: 14px;
    border-radius: 7px;
    border: 1px solid rgba(0, 255, 204, 0.2);
}

QScrollBar::handle:horizontal {
    background: qlineargradient(x1:0, y1:0, x2:0, y2:1,
        stop:0 #00ffcc, stop:1 #00ff88);
    border-radius: 6px;
    min-width: 30px;
}

/* Quantum List Widget */
QListWidget {
    background: rgba(10, 14, 26, 0.8);
    border: 2px solid #00ffcc;
    border-radius: 8px;
    padding: 8px;
    outline: none;
}

QListWidget::item {
    background: transparent;
    padding: 8px;
    margin: 2px 0;
    border-radius: 4px;
}

QListWidget::item:selected {
    background: qlineargradient(x1:0, y1:0, x2:1, y2:0,
        stop:0 rgba(0, 255, 204, 0.3), stop:1 rgba(0, 255, 136, 0.3));
    border-left: 4px solid #00ffcc;
}

QListWidget::item:hover {
    background: rgba(0, 255, 204, 0.1);
}

/* Quantum Text Edit */
QTextEdit, QPlainTextEdit {
    background: rgba(10, 14, 26, 0.9);
    border: 2px solid #00ffcc;
    border-radius: 8px;
    padding: 12px;
    color: #e0e0e0;
    font-family: "JetBrains Mono", monospace;
    font-size: 13px;
}

QTextEdit:focus, QPlainTextEdit:focus {
    border-color: #00ff88;
    background: rgba(10, 14, 26, 1.0);
}

/* Quantum Line Edit */
QLineEdit {
    background: rgba(10, 14, 26, 0.8);
    border: 2px solid #00ffcc;
    border-radius: 6px;
    padding: 8px 12px;
    color: #00ffcc;
    font-size: 14px;
}

QLineEdit:focus {
    border-color: #00ff88;
    background: rgba(10, 14, 26, 1.0);
    box-shadow: 0 0 8px rgba(0, 255, 136, 0.3);
}

/* Quantum Progress Bar */
QProgressBar {
    background: rgba(10, 14, 26, 0.8);
    border: 2px solid #00ffcc;
    border-radius: 6px;
    text-align: center;
    color: #00ffcc;
    height: 24px;
    font-weight: bold;
}

QProgressBar::chunk {
    background: qlineargradient(x1:0, y1:0, x2:1, y2:0,
        stop:0 #00ffcc, stop:0.5 #00ff88, stop:1 #00ccff);
    border-radius: 4px;
}

/* Quantum Menu Bar */
QMenuBar {
    background: #0a0e1a;
    border-bottom: 2px solid #00ffcc;
    padding: 4px;
}

QMenuBar::item {
    background: transparent;
    padding: 8px 16px;
    color: #00ffcc;
    border-radius: 4px;
}

QMenuBar::item:selected {
    background: rgba(0, 255, 204, 0.2);
}

QMenu {
    background: #0a0e1a;
    border: 2px solid #00ffcc;
    border-radius: 8px;
    padding: 8px;
}

QMenu::item {
    padding: 8px 32px;
    color: #00ffcc;
    border-radius: 4px;
}

QMenu::item:selected {
    background: rgba(0, 255, 204, 0.3);
}

/* Quantum Tool Bar */
QToolBar {
    background: qlineargradient(x1:0, y1:0, x2:0, y2:1,
        stop:0 #1a2332, stop:1 #0f1621);
    border: none;
    spacing: 8px;
    padding: 8px;
}

QToolButton {
    background: transparent;
    border: 2px solid transparent;
    border-radius: 6px;
    padding: 8px;
    color: #00ffcc;
}

QToolButton:hover {
    background: rgba(0, 255, 204, 0.1);
    border-color: #00ffcc;
}

QToolButton:pressed {
    background: rgba(0, 255, 204, 0.2);
}

/* Quantum Dock Widget */
QDockWidget {
    color: #00ffcc;
    border: 2px solid #00ffcc;
    border-radius: 8px;
}

QDockWidget::title {
    background: qlineargradient(x1:0, y1:0, x2:0, y2:1,
        stop:0 #1a2332, stop:1 #0f1621);
    padding: 12px;
    border-top-left-radius: 8px;
    border-top-right-radius: 8px;
    font-weight: bold;
}

/* Quantum Status Bar */
QStatusBar {
    background: #0a0e1a;
    border-top: 2px solid #00ffcc;
    color: #00ffcc;
    padding: 8px;
}

QStatusBar::item {
    border: none;
}

/* Quantum Slider */
QSlider::groove:horizontal {
    border: 1px solid #00ffcc;
    height: 6px;
    background: #0a0e1a;
    border-radius: 3px;
}

QSlider::handle:horizontal {
    background: #00ffcc;
    border: 1px solid #00ff88;
    width: 16px;
    border-radius: 8px;
    margin: -5px 0;
}

QSlider::handle:horizontal:hover {
    background: #00ff88;
    box-shadow: 0 0 8px rgba(0, 255, 136, 0.5);
}

/* Quantum Check Box */
QCheckBox {
    color: #00ffcc;
    spacing: 8px;
}

QCheckBox::indicator {
    width: 18px;
    height: 18px;
    border: 2px solid #00ffcc;
    border-radius: 4px;
    background: rgba(10, 14, 26, 0.8);
}

QCheckBox::indicator:checked {
    background: #00ffcc;
    border-color: #00ff88;
}

QCheckBox::indicator:hover {
    border-color: #00ff88;
    box-shadow: 0 0 6px rgba(0, 255, 136, 0.3);
}

/* Quantum Radio Button */
QRadioButton {
    color: #00ffcc;
    spacing: 8px;
}

QRadioButton::indicator {
    width: 18px;
    height: 18px;
    border: 2px solid #00ffcc;
    border-radius: 9px;
    background: rgba(10, 14, 26, 0.8);
}

QRadioButton::indicator:checked {
    background: radial-gradient(circle, #00ffcc 30%, rgba(10, 14, 26, 0.8) 30%);
    border-color: #00ff88;
}

/* Special Quantum Effects */
.quantum-glow {
    box-shadow: 0 0 20px rgba(0, 255, 204, 0.6),
                0 0 40px rgba(0, 255, 204, 0.4),
                0 0 60px rgba(0, 255, 204, 0.2);
}

.quantum-pulse {
    animation: pulse 2s ease-in-out infinite;
}

@keyframes pulse {
    0% { opacity: 1; }
    50% { opacity: 0.7; }
    100% { opacity: 1; }
}

.quantum-wave {
    background: repeating-linear-gradient(
        45deg,
        transparent,
        transparent 10px,
        rgba(0, 255, 204, 0.1) 10px,
        rgba(0, 255, 204, 0.1) 20px
    );
}

/* Application-Specific Styles */

/* RFT Visualizer */
.rft-visualizer {
    background: radial-gradient(ellipse at center,
        rgba(0, 255, 204, 0.05) 0%,
        transparent 70%);
}

.rft-graph {
    background: rgba(10, 14, 26, 0.95);
    border: 1px solid #00ffcc;
    border-radius: 8px;
}

/* Quantum Crypto */
.crypto-container {
    background: linear-gradient(135deg,
        rgba(0, 255, 204, 0.1) 0%,
        rgba(0, 204, 255, 0.1) 100%);
    border: 2px solid #00ffcc;
    border-radius: 12px;
}

.encryption-indicator {
    background: conic-gradient(from 0deg,
        #00ffcc, #00ff88, #00ccff, #00ffcc);
    width: 24px;
    height: 24px;
    border-radius: 50%;
}

/* System Monitor */
.system-monitor-graph {
    background: rgba(10, 14, 26, 0.9);
    border: 1px solid #00ffcc;
    border-radius: 8px;
}

.cpu-usage-bar {
    background: #00ffcc;
}

.memory-usage-bar {
    background: #00ccff;
}

/* Quantum Browser */
.qbrowser-tab {
    background: rgba(26, 35, 50, 0.9);
    border-top: 3px solid transparent;
}

.qbrowser-tab.active {
    border-top-color: #00ffcc;
    background: rgba(42, 51, 66, 0.9);
}

.qbrowser-addressbar {
    background: rgba(10, 14, 26, 0.95);
    border: 2px solid rgba(0, 255, 204, 0.3);
    border-radius: 20px;
    padding: 8px 16px;
}
